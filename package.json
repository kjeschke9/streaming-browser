{
  "name": "streaming-browser-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/backend",
    "apps/mobile",
    "apps/tizen"
  ],
  "scripts": {
    "dev:backend": "yarn workspace @streambrws/backend dev",
    "dev:mobile": "yarn workspace @streambrws/mobile start",
    "dev:tizen": "yarn workspace @streambrws/tizen dev",
    "build:backend": "yarn workspace @streambrws/backend build",
    "build:tizen": "yarn workspace @streambrws/tizen build",
    "build:shared": "yarn workspaces run build --filter=./packages/*",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4"
  }
}
