# StreamHub Backend — Local Dev Environment
# Copy this to apps/backend/.env

PORT=4000
NODE_ENV=development

# Database (matches docker-compose)
DATABASE_URL=postgresql://streamhub:streamhub_secret@localhost:5432/streamhub
DB_HOST=localhost
DB_PORT=5432
DB_NAME=streamhub
DB_USER=streamhub
DB_PASSWORD=streamhub_secret

# Auth
JWT_SECRET=local_dev_secret_replace_in_production
JWT_EXPIRY=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:5173

# TMDB (get your free key at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_key_here

LOG_LEVEL=info
