{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
          "outDir": "./dist",
          "rootDir": "./src",
          "module": "CommonJS",
          "target": "ES2020",
          "skipLibCheck": true,
          "strictNullChecks": false,
          "noEmitOnError": false,
          "paths": {
                  "@streambrws/shared-types": ["../../packages/shared-types/src"]
          }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
