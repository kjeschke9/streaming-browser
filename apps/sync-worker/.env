DATABASE_URL=postgresql://streamhub:streamhub_secret@localhost:5432/streamhub
NODE_ENV=development

# ─── TMDB Integration ────────────────────────────────────────────────────────
# Get a free API key at https://www.themoviedb.org/settings/api
# When set, the sync-worker uses REAL movie/TV data from TMDB instead of mock data.
# Leave blank to use MockAdapter (fictional titles, no network needed).
TMDB_API_KEY=

# Set to 'true' to run one sync cycle and exit (useful for testing)
SYNC_ONCE=false
