<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="com.streambrws.tizen"
        version="1.0.0">

  <tizen:application id="com.streambrws.tizen.StreamBrws"
                     package="com.streambrws.tizen"
                     required_version="6.0"/>

  <content src="index.html"/>
  <name>StreamBrws</name>
  <description>Your streaming feed. Your rules.</description>
  <author email="dev@streambrws.com">StreamBrws Team</author>

  <tizen:privilege name="http://tizen.org/privilege/internet"/>
  <tizen:privilege name="http://tizen.org/privilege/storage"/>

  <tizen:setting screen-orientation="landscape"
                 context-menu="disable"
                 background-support="disable"
                 encryption="disable"
                 install-location="auto"
                 hwkey-event="enable"/>

  <icon src="icon.png"/>

  <feature name="http://tizen.org/feature/screen.size.normal.1920.1080"/>
</widget>
